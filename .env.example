PHOTOVAULT_HTTP_PORT=8080
MAILPIT_UI_PORT=8025
PHOTOVAULT_ENV=development
WORDPRESS_DEBUG=1
WORDPRESS_FORCE_SSL_ADMIN=0
WORDPRESS_HOME_URL=
WORDPRESS_SITE_URL=
PHOTOVAULT_TRUST_PROXY_HEADERS=0
WORDPRESS_MAIL_FROM=wordpress@photovault.local
WORDPRESS_MAIL_FROM_NAME=PhotoVault

PHOTOVAULT_SMTP_MODE=mailpit
PHOTOVAULT_SMTP_HOST=mailpit
PHOTOVAULT_SMTP_PORT=1025
PHOTOVAULT_SMTP_USER=
PHOTOVAULT_SMTP_PASSWORD=
PHOTOVAULT_SMTP_FROM=
PHOTOVAULT_SMTP_TLS=off
PHOTOVAULT_SMTP_STARTTLS=off

WORDPRESS_DB_NAME=photovault
WORDPRESS_DB_USER=photovault
WORDPRESS_DB_PASSWORD=replace-with-generated-secret
MARIADB_ROOT_PASSWORD=replace-with-generated-secret
WORDPRESS_TABLE_PREFIX=wp_

WORDPRESS_AUTH_KEY=replace-with-generated-secret
WORDPRESS_SECURE_AUTH_KEY=replace-with-generated-secret
WORDPRESS_LOGGED_IN_KEY=replace-with-generated-secret
WORDPRESS_NONCE_KEY=replace-with-generated-secret
WORDPRESS_AUTH_SALT=replace-with-generated-secret
WORDPRESS_SECURE_AUTH_SALT=replace-with-generated-secret
WORDPRESS_LOGGED_IN_SALT=replace-with-generated-secret
WORDPRESS_NONCE_SALT=replace-with-generated-secret
